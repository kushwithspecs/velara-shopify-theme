[
  {
    "name": "theme_info",
    "theme_name": "Velara",
    "theme_version": "1.0.0",
    "theme_author": "Velara",
    "theme_documentation_url": "https://github.com/velara/velara-theme",
    "theme_support_url": "mailto:hello@velara.in"
  },
  {
    "name": "Brand",
    "settings": [
      {
        "type": "text",
        "id": "brand_name",
        "label": "Brand name",
        "default": "VELARA"
      },
      {
        "type": "text",
        "id": "tagline",
        "label": "Tagline",
        "default": "Skin is not a canvas. It's a ritual."
      },
      {
        "type": "image_picker",
        "id": "logo",
        "label": "Optional brand logo (overrides text)"
      },
      {
        "type": "image_picker",
        "id": "social_share_image",
        "label": "Social share image (Open Graph)"
      }
    ]
  },
  {
    "name": "Colours",
    "settings": [
      {
        "type": "color",
        "id": "color_accent_green",
        "label": "Accent — Green",
        "default": "#C3E794"
      },
      {
        "type": "color",
        "id": "color_accent_warm",
        "label": "Accent — Warm brown",
        "default": "#483F36"
      },
      {
        "type": "color",
        "id": "color_border",
        "label": "Border / Off-white",
        "default": "#ECECE4"
      }
    ]
  },
  {
    "name": "Typography",
    "settings": [
      {
        "type": "select",
        "id": "font_display",
        "label": "Display font",
        "options": [
          { "value": "Clash Display", "label": "Clash Display" },
          { "value": "Cormorant Garamond", "label": "Cormorant Garamond" }
        ],
        "default": "Clash Display"
      },
      {
        "type": "select",
        "id": "font_body",
        "label": "Body font",
        "options": [
          { "value": "Inter", "label": "Inter" },
          { "value": "DM Sans", "label": "DM Sans" }
        ],
        "default": "Inter"
      }
    ]
  },
  {
    "name": "Cart",
    "settings": [
      {
        "type": "checkbox",
        "id": "free_shipping_enabled",
        "label": "Enable free shipping progress bar",
        "default": true
      },
      {
        "type": "number",
        "id": "free_shipping_threshold",
        "label": "Free shipping threshold (in store currency)",
        "default": 1500
      }
    ]
  },
  {
    "name": "Social",
    "settings": [
      { "type": "url", "id": "social_instagram", "label": "Instagram URL" },
      { "type": "url", "id": "social_tiktok", "label": "TikTok URL" },
      { "type": "url", "id": "social_youtube", "label": "YouTube URL" }
    ]
  }
]
