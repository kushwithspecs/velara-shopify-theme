{%- comment -%}
  Reusable product card. Reads from product metafields:
    - product.metafields.custom.tagline   (string)   — short benefit line
    - product.metafields.custom.promo_badge (string) — gift/offer pill
    - product.metafields.reviews.rating   (number)   — 0..5 (optional)
    - product.metafields.reviews.rating_count (int)  — # reviews (optional)
  Tags used:  `new`, `best-loved` / `best-seller`
  Accepts: product (required), lazy (default true)
{%- endcomment -%}

{%- assign loading_attr = 'lazy' -%}
{%- if lazy == false -%}{%- assign loading_attr = 'eager' -%}{%- endif -%}

{%- if product == blank -%}
  <article class="product-card product-card--placeholder">
    <a href="#" class="product-card__media">
      <div class="product-card__placeholder"></div>
    </a>
    <div class="product-card__body">
      <a href="#" class="product-card__title">Product name</a>
      <div class="product-card__price-row">
        <span class="product-card__price"><span class="product-card__currency">{{ cart.currency.symbol | default: '₹' }}</span>000</span>
      </div>
    </div>
  </article>
{%- else -%}
  {%- assign current_variant = product.selected_or_first_available_variant -%}
  {%- assign on_sale = false -%}
  {%- if product.compare_at_price > product.price -%}{%- assign on_sale = true -%}{%- endif -%}
  {%- assign rating = product.metafields.reviews.rating.value | default: product.metafields.custom.rating | default: 0 -%}
  {%- assign rating_count = product.metafields.reviews.rating_count.value | default: product.metafields.custom.rating_count -%}
  {%- assign tagline = product.metafields.custom.tagline -%}
  {%- assign promo = product.metafields.custom.promo_badge -%}

  <article class="product-card" data-product-card>
    <a href="{{ product.url }}" class="product-card__media" aria-label="{{ product.title | escape }}">
      {%- if product.tags contains 'new' -%}
        <span class="sticker sticker--new">new</span>
      {%- elsif product.tags contains 'best-loved' or product.tags contains 'best-seller' -%}
        <span class="sticker sticker--loved">skin loved</span>
      {%- endif -%}

      {%- if product.featured_image -%}
        {{ product.featured_image | image_url: width: 1200 | image_tag:
           loading: loading_attr,
           width: product.featured_image.width,
           height: product.featured_image.height,
           alt: product.featured_image.alt | default: product.title,
           sizes: '(min-width: 1200px) 33vw, (min-width: 810px) 50vw, 100vw' }}
      {%- else -%}
        <div class="product-card__placeholder"></div>
      {%- endif -%}
    </a>

    <div class="product-card__body">
      <a href="{{ product.url }}" class="product-card__title">{{ product.title }}</a>

      <div class="product-card__meta-row">
        {%- if rating > 0 -%}
          <div class="product-card__rating" aria-label="{{ rating }} out of 5 stars">
            {%- assign full_stars = rating | floor -%}
            {%- for i in (1..5) -%}
              {%- if i <= full_stars -%}
                <svg class="star star--filled" viewBox="0 0 12 12" width="12" height="12" aria-hidden="true"><path d="M6 .8l1.5 3.4 3.7.4-2.8 2.5.8 3.6L6 8.9 2.8 10.7l.8-3.6L.8 4.6l3.7-.4z"/></svg>
              {%- else -%}
                <svg class="star star--empty" viewBox="0 0 12 12" width="12" height="12" aria-hidden="true"><path d="M6 .8l1.5 3.4 3.7.4-2.8 2.5.8 3.6L6 8.9 2.8 10.7l.8-3.6L.8 4.6l3.7-.4z"/></svg>
              {%- endif -%}
            {%- endfor -%}
            {%- if rating_count -%}<span class="product-card__rating-count">({{ rating_count }})</span>{%- endif -%}
          </div>
        {%- endif -%}

        <div class="product-card__price-row">
          {%- if on_sale -%}
            <s class="product-card__compare"><span class="product-card__currency">{{ cart.currency.symbol | default: '₹' }}</span>{{ product.compare_at_price | money_without_currency }}</s>
          {%- endif -%}
          <span class="product-card__price"><span class="product-card__currency">{{ cart.currency.symbol | default: '₹' }}</span>{{ product.price | money_without_currency }}</span>
        </div>
      </div>

      {%- if tagline != blank -%}
        <p class="product-card__tagline">{{ tagline }}</p>
      {%- endif -%}

      {%- if promo != blank -%}
        <span class="product-card__promo">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.4" aria-hidden="true">
            <rect x="1.5" y="4.5" width="11" height="8" rx="1"/>
            <line x1="1.5" y1="7.5" x2="12.5" y2="7.5"/>
            <line x1="7" y1="4.5" x2="7" y2="12.5"/>
            <path d="M7 4.5C7 3 5.5 2 4.5 2.5S4 4.5 5 4.5h2"/>
            <path d="M7 4.5C7 3 8.5 2 9.5 2.5S10 4.5 9 4.5H7"/>
          </svg>
          {{ promo }}
        </span>
      {%- endif -%}

      <form method="post" action="{{ routes.cart_add_url }}" class="product-card__form" data-card-add-form>
        <input type="hidden" name="id" value="{{ current_variant.id }}">
        {%- if product.has_only_default_variant and current_variant.available -%}
          <button type="submit" class="product-card__cta" data-card-add aria-label="Add {{ product.title | escape }} to cart">
            ADD TO CART
          </button>
        {%- elsif current_variant.available == false -%}
          <a href="{{ product.url }}" class="product-card__cta product-card__cta--ghost">SOLD OUT</a>
        {%- else -%}
          <a href="{{ product.url }}" class="product-card__cta">CHOOSE OPTIONS</a>
        {%- endif -%}
      </form>
    </div>
  </article>
{%- endif -%}

<style>
  .product-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    color: var(--color-black);
    transition: transform var(--transition-base);
  }
  .product-card:hover { transform: translateY(-4px); }

  /* Image */
  .product-card__media {
    position: relative;
    aspect-ratio: 3 / 4;
    overflow: hidden;
    border-radius: var(--radius-lg);
    border: 2px solid var(--color-black);
    background-color: var(--color-white);
    box-shadow: 6px 6px 0 var(--color-black);
    transition: box-shadow var(--transition-base);
    display: block;
  }
  .product-card:hover .product-card__media { box-shadow: 3px 3px 0 var(--color-black); }
  .product-card__media img { width: 100%; height: 100%; object-fit: contain; transition: transform var(--transition-slow); }
  .product-card:hover .product-card__media img { transform: scale(1.05); }
  .product-card__placeholder {
    width: 100%; height: 100%;
    background: linear-gradient(135deg, var(--color-pink-soft) 0%, var(--color-yellow-soft) 100%);
  }

  /* Body */
  .product-card__body {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding-inline: 4px;
  }

  .product-card__title {
    font-family: var(--font-display);
    font-variation-settings: "opsz" 100, "SOFT" 80;
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--color-black);
    text-decoration: none;
    line-height: 1.15;
  }
  .product-card__title:hover { color: var(--color-terracotta); }

  /* Rating + price on one row */
  .product-card__meta-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-2);
    flex-wrap: wrap;
  }

  .product-card__rating { display: inline-flex; align-items: center; gap: 2px; }
  .product-card__rating .star { fill: var(--color-black); }
  .product-card__rating .star--empty { fill: rgba(28,28,32,0.18); }
  .product-card__rating-count {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    color: rgba(28,28,32,0.6);
    margin-left: 6px;
    font-weight: 500;
  }

  .product-card__price-row {
    display: inline-flex;
    align-items: baseline;
    gap: 8px;
    font-family: var(--font-body);
    font-weight: 700;
    font-size: var(--text-lg);
  }
  .product-card__compare {
    color: rgba(28,28,32,0.4);
    font-size: var(--text-sm);
    font-weight: 500;
    text-decoration: line-through;
  }
  .product-card__currency {
    font-size: 0.85em;
    margin-right: 2px;
    color: var(--color-terracotta);
    font-weight: 600;
  }
  .product-card__compare .product-card__currency { color: inherit; }

  .product-card__tagline {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: rgba(28,28,32,0.75);
    line-height: 1.35;
    margin: 0;
  }

  /* Promo pill */
  .product-card__promo {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 12px;
    border-radius: var(--radius-pill);
    background-color: var(--color-lavender);
    color: var(--color-black);
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    width: max-content;
    max-width: 100%;
  }
  .product-card__promo svg { flex-shrink: 0; }

  /* Add to cart CTA */
  .product-card__form { margin: 0; margin-top: 4px; }
  .product-card__cta {
    display: block;
    width: 100%;
    padding: 14px 16px;
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-align: center;
    color: var(--color-black);
    background-color: var(--color-mint);
    border: 2px solid var(--color-black);
    border-radius: var(--radius-md);
    cursor: pointer;
    transition: background-color var(--transition-base), transform var(--transition-base);
    text-decoration: none;
  }
  .product-card__cta:hover { background-color: var(--color-yellow); }
  .product-card__cta:active { transform: translateY(1px); }
  .product-card__cta--ghost { background-color: transparent; color: rgba(28,28,32,0.5); border-style: dashed; }
  .product-card__cta--ghost:hover { background-color: transparent; }

  /* Stickers (existing) */
  .sticker {
    position: absolute;
    top: 16px; left: 16px;
    z-index: 2;
    padding: 8px 14px;
    border-radius: var(--radius-pill);
    border: 1.5px solid var(--color-black);
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    transform: rotate(-6deg);
    transition: transform var(--transition-base);
    background: var(--color-pink);
  }
  .product-card:hover .sticker { transform: rotate(-3deg) scale(1.05); }
  .sticker--sale { background: var(--color-red); color: var(--color-white); }
  .sticker--new { background: var(--color-yellow); }
  .sticker--loved {
    background: var(--color-mint);
    top: auto; left: auto;
    bottom: 16px; right: 16px;
    transform: rotate(8deg);
  }
  .product-card:hover .sticker--loved { transform: rotate(4deg) scale(1.05); }
  .sticker--loved::before { content: "♡ "; }
</style>
