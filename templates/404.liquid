<section class="container" style="padding-block: var(--space-12); text-align: center;">
  <h1 style="font-family: var(--font-display); font-size: clamp(4rem, 12vw, 10rem); font-weight: 500; letter-spacing: var(--tracking-tight); margin-bottom: var(--space-2); color: var(--color-accent-green);">
    404
  </h1>
  <h2 style="font-family: var(--font-display); font-size: clamp(1.5rem, 3vw, 2.5rem); font-weight: 500; margin-bottom: var(--space-2);">
    {{ '404.title' | t }}
  </h2>
  <p style="font-family: var(--font-body); color: var(--color-accent-warm); font-size: var(--text-lg); margin-bottom: var(--space-4); max-width: 40ch; margin-inline: auto;">
    {{ '404.body' | t }}
  </p>
  <a href="{{ routes.root_url }}" class="btn btn--primary">{{ '404.cta' | t }}</a>
</section>
