<style>
  .story-hero {
    position: relative;
    aspect-ratio: 16 / 8;
    overflow: hidden;
    background-color: var(--color-border);
    isolation: isolate;
  }
  @media (max-width: 809.98px) { .story-hero { aspect-ratio: 4 / 5; } }

  .story-hero__image { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
  .story-hero__overlay { position: absolute; inset: 0; background: linear-gradient(180deg, rgba(0,0,0,0.0) 0%, rgba(0,0,0,0.5) 100%); }
  .story-hero__content { position: relative; height: 100%; display: flex; align-items: flex-end; padding-block: var(--space-6); color: var(--color-white); }

  .story-hero__title {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 7vw, 6rem);
    font-weight: 500;
    letter-spacing: var(--tracking-tight);
  }

  .story-body {
    max-width: 70ch;
    margin-inline: auto;
    font-family: var(--font-body);
    font-size: var(--text-lg);
    line-height: 1.7;
    color: var(--color-accent-warm);
  }
  .story-body p + p { margin-top: var(--space-2); }

  .story-pull-quote {
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(1.5rem, 3.5vw, 2.5rem);
    color: var(--color-black);
    max-width: 28ch;
    margin: var(--space-8) auto;
    text-align: center;
    line-height: 1.2;
  }

  .story-values {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-5);
  }
  @media (max-width: 809.98px) { .story-values { grid-template-columns: 1fr; } }

  .story-value h3 {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 500;
    margin-bottom: var(--space-1);
  }
  .story-value p {
    font-family: var(--font-body);
    color: var(--color-accent-warm);
    line-height: 1.6;
  }
</style>

<section class="story-hero">
  {%- if section.settings.hero_image -%}
    {{ section.settings.hero_image | image_url: width: 2400 | image_tag:
       loading: 'eager',
       class: 'story-hero__image parallax-img',
       width: section.settings.hero_image.width,
       height: section.settings.hero_image.height,
       alt: section.settings.hero_title }}
  {%- else -%}
    <div class="story-hero__image" style="background: linear-gradient(135deg, var(--color-accent-warm) 0%, #2a241e 100%);"></div>
  {%- endif -%}
  <div class="story-hero__overlay"></div>
  <div class="container story-hero__content">
    <h1 class="story-hero__title">{{ section.settings.hero_title | default: 'Our Story' }}</h1>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="story-body">{{ page.content }}</div>

    {%- if section.settings.pull_quote != blank -%}
      <p class="story-pull-quote">"{{ section.settings.pull_quote }}"</p>
    {%- endif -%}

    <div class="story-values">
      {%- for block in section.blocks -%}
        <div class="story-value" {{ block.shopify_attributes }}>
          <h3>{{ block.settings.title }}</h3>
          <p>{{ block.settings.body }}</p>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Our Story",
  "settings": [
    { "type": "text", "id": "hero_title", "label": "Hero title", "default": "Our Story" },
    { "type": "image_picker", "id": "hero_image", "label": "Hero image" },
    { "type": "text", "id": "pull_quote", "label": "Pull quote", "default": "Skin is not a canvas. It's a ritual." }
  ],
  "blocks": [
    {
      "type": "value",
      "name": "Value",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "Clean" },
        { "type": "textarea", "id": "body", "label": "Body", "default": "Formulas free from parabens, sulphates and silicones." }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Our Story",
      "blocks": [
        { "type": "value", "settings": { "title": "Clean", "body": "Formulas free from parabens, sulphates and silicones." } },
        { "type": "value", "settings": { "title": "Science", "body": "Every ingredient backed by peer-reviewed research." } },
        { "type": "value", "settings": { "title": "Sustainable", "body": "Recyclable packaging and a carbon-neutral supply chain." } }
      ]
    }
  ]
}
{% endschema %}
