<style>
  .brand-intro {
    background-color: var(--color-pink-soft);
    position: relative;
    overflow: hidden;
  }
  .brand-intro::before {
    content: "";
    position: absolute;
    width: 200px; height: 200px;
    background: var(--color-yellow);
    border-radius: 50%;
    top: -80px; right: 10%;
    opacity: 0.4;
    filter: blur(20px);
  }

  .brand-intro__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
    align-items: center;
    position: relative;
    z-index: 1;
  }
  @media (min-width: 1200px) {
    .brand-intro__grid { grid-template-columns: 1fr 1fr; gap: var(--space-12); }
  }

  .brand-intro__text {
    font-family: var(--font-display);
    font-variation-settings: "opsz" 144, "SOFT" 100;
    font-weight: 500;
    line-height: 1;
    color: var(--color-black);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .brand-intro__line-1 {
    font-size: clamp(2rem, 4.5vw, 4rem);
    max-width: 14ch;
  }

  /* Group line 2 + line 3 tightly so they read as one continuous phrase */
  .brand-intro__phrase {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .brand-intro__line-2 {
    font-size: clamp(1.5rem, 3vw, 2.5rem);
    align-self: flex-start;
    font-style: italic;
    color: var(--color-terracotta);
    font-family: var(--font-script);
    font-weight: 600;
    transform: rotate(-2deg) translateX(8px);
    transform-origin: left center;
    line-height: 1.1;
  }

  .brand-intro__line-3 {
    font-size: clamp(2rem, 4.5vw, 4rem);
    line-height: 1;
  }

  .brand-intro__cards {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-3);
    min-width: 0;
  }
  @media (max-width: 809.98px) {
    .brand-intro__cards { grid-template-columns: 1fr; gap: var(--space-4); }
  }

  .book-card {
    position: relative;
    aspect-ratio: 3 / 4;
    min-width: 0;
    transition: transform var(--transition-base);
  }

  .book-card__cover {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
    border-radius: var(--radius-lg);
    border: 2px solid var(--color-black);
    box-shadow: 8px 8px 0 var(--color-black);
    transition: box-shadow var(--transition-base), transform var(--transition-base);
  }
  .book-card:hover .book-card__cover {
    box-shadow: 4px 4px 0 var(--color-black);
    transform: translate(2px, 2px);
  }

  .book-card__cover img { width: 100%; height: 100%; object-fit: cover; }

  .book-card:nth-child(1) .book-card__cover { background-color: var(--color-yellow-soft); }
  .book-card:nth-child(2) .book-card__cover { background-color: var(--color-lavender-soft); }

  .book-card__meta {
    margin-top: var(--space-2);
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .book-card__name {
    font-family: var(--font-display);
    font-variation-settings: "SOFT" 80;
    font-size: var(--text-xl);
    font-weight: 600;
    color: var(--color-black);
  }

  .book-card__descriptor {
    font-family: var(--font-script);
    font-size: var(--text-base);
    color: var(--color-terracotta);
  }

  .book-card__placeholder {
    width: 100%; height: 100%;
    display: flex; align-items: center; justify-content: center;
    font-family: var(--font-display);
    font-size: var(--text-4xl);
    color: var(--color-terracotta);
    opacity: 0.4;
  }
</style>

<section class="section brand-intro">
  <div class="container">
    <div class="brand-intro__grid">
      <div class="brand-intro__text reveal">
        <span class="brand-intro__line-1">{{ section.settings.line_1 }}</span>
        <div class="brand-intro__phrase">
          <span class="brand-intro__line-2">{{ section.settings.line_2 }}</span>
          <span class="brand-intro__line-3">{{ section.settings.line_3 }}</span>
        </div>
      </div>

      <div class="brand-intro__cards reveal">
        {%- for block in section.blocks limit: 2 -%}
          <div class="book-card" data-3d-card {{ block.shopify_attributes }}>
            <div class="book-card__cover">
              {%- if block.settings.image -%}
                {{ block.settings.image | image_url: width: 800 | image_tag:
                   loading: 'lazy',
                   width: block.settings.image.width,
                   height: block.settings.image.height,
                   alt: block.settings.name,
                   sizes: '(min-width: 1200px) 35vw, (min-width: 810px) 45vw, 90vw' }}
              {%- else -%}
                <div class="book-card__placeholder">{{ block.settings.name | slice: 0, 1 }}</div>
              {%- endif -%}
            </div>
            <div class="book-card__meta">
              <span class="book-card__name">{{ block.settings.name }}</span>
              <span class="book-card__descriptor">{{ block.settings.descriptor }}</span>
            </div>
          </div>
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Brand Intro",
  "settings": [
    { "type": "text", "id": "line_1", "label": "Statement line 1", "default": "A modern skincare atelier" },
    { "type": "text", "id": "line_2", "label": "Statement line 2 (script)", "default": "best formulas for" },
    { "type": "text", "id": "line_3", "label": "Statement line 3", "default": "skin that glows." }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Product card",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "name", "label": "Name", "default": "Velvet Glow" },
        { "type": "text", "id": "descriptor", "label": "Descriptor", "default": "fresh, radiant, uplifting" }
      ]
    }
  ],
  "max_blocks": 2,
  "presets": [
    {
      "name": "Brand Intro",
      "blocks": [
        { "type": "card", "settings": { "name": "Velvet Glow", "descriptor": "fresh, radiant, uplifting" } },
        { "type": "card", "settings": { "name": "Earth Balm", "descriptor": "warm, grounding, restorative" } }
      ]
    }
  ]
}
{% endschema %}
