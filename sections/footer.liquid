<style>
  .site-footer {
    background-color: var(--color-black);
    color: var(--color-cream);
    padding-block: var(--space-10) var(--space-4);
    position: relative;
    overflow: hidden;
    border-radius: var(--radius-xl) var(--radius-xl) 0 0;
    margin-top: var(--space-6);
  }

  .site-footer__top {
    display: grid;
    gap: var(--space-6);
    padding-bottom: var(--space-8);
    border-bottom: 2px dashed var(--color-mint);
  }

  .site-footer__tagline {
    font-family: var(--font-display);
    font-variation-settings: "opsz" 144, "SOFT" 100;
    font-size: clamp(1.75rem, 3.2vw, 3rem);
    line-height: 1.1;
    color: var(--color-mint);
    max-width: 22ch;
    font-weight: 600;
  }
  .site-footer__tagline em {
    color: var(--color-pink);
    font-style: italic;
    font-family: var(--font-script);
  }

  .site-footer__contact {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
  }
  @media (min-width: 810px) {
    .site-footer__contact { grid-template-columns: repeat(3, 1fr); gap: var(--space-6); }
  }

  .contact-block__label {
    display: block;
    font-family: var(--font-body);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-pink);
    margin-bottom: var(--space-1);
    font-weight: 600;
  }

  .contact-block__value {
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: var(--color-cream);
    line-height: 1.5;
    transition: color var(--transition-base);
  }
  a.contact-block__value:hover { color: var(--color-yellow); }

  .site-footer__bottom {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    padding-top: var(--space-4);
    margin-top: var(--space-4);
    position: relative;
    z-index: 2;
  }

  .site-footer__copyright {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-mint);
    font-weight: 600;
  }

  .site-footer__legal { display: flex; gap: var(--space-2); }
  .site-footer__legal a {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    color: var(--color-cream);
    padding: 6px 14px;
    border-radius: var(--radius-pill);
    border: 1.5px solid var(--color-mint);
    font-weight: 500;
    transition: background-color var(--transition-base), color var(--transition-base);
  }
  .site-footer__legal a:hover { background-color: var(--color-mint); color: var(--color-black); }

  .site-footer__watermark {
    position: relative;
    width: 100%;
    margin-top: var(--space-6);
    line-height: 0.85;
    user-select: none;
    pointer-events: none;
    text-align: center;
  }
  .site-footer__watermark-svg { width: 100%; height: auto; display: block; }
  .site-footer__watermark text {
    font-family: var(--font-display);
    font-weight: 700;
    font-style: italic;
    fill: var(--color-mint);
    letter-spacing: -0.04em;
  }

  .site-footer__watermark-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    mix-blend-mode: overlay;
    opacity: 0.4;
  }
</style>

<footer class="site-footer">
  <div class="container">
    <div class="site-footer__top">
      <h2 class="site-footer__tagline">{{ section.settings.tagline | default: 'footer.tagline' | t }}</h2>

      <div class="site-footer__contact">
        <div class="contact-block">
          <span class="contact-block__label">{{ 'footer.address_label' | t }}</span>
          <span class="contact-block__value">{{ section.settings.address | default: 'footer.address_value' | t }}</span>
        </div>
        <div class="contact-block">
          <span class="contact-block__label">{{ 'footer.enquiry_label' | t }}</span>
          <a class="contact-block__value" href="mailto:{{ section.settings.email | default: 'hello@velara.in' }}">
            {{ section.settings.email | default: 'hello@velara.in' }}
          </a>
        </div>
        <div class="contact-block">
          <span class="contact-block__label">{{ 'footer.phone_label' | t }}</span>
          <a class="contact-block__value" href="tel:{{ section.settings.phone | default: '+919876543210' | replace: ' ', '' }}">
            {{ section.settings.phone | default: '+91 98765 43210' }}
          </a>
        </div>
      </div>
    </div>

    <div class="site-footer__watermark" aria-hidden="true">
      <svg class="site-footer__watermark-svg" viewBox="0 0 1000 180" preserveAspectRatio="xMidYMid meet">
        <text x="50%" y="78%" text-anchor="middle" font-size="195" font-family="Clash Display, serif">
          {{ shop.name | upcase | default: 'VELARA' }}
        </text>
      </svg>
      <canvas class="site-footer__watermark-canvas" data-footer-canvas></canvas>
    </div>

    <div class="site-footer__bottom">
      <span class="site-footer__copyright">© {{ 'now' | date: '%Y' }} {{ 'footer.copyright' | t }}</span>
      <nav class="site-footer__legal" aria-label="Legal">
        <a href="/policies/refund-policy">{{ 'footer.return_policy' | t }}</a>
        <a href="/policies/terms-of-service">{{ 'footer.terms' | t }}</a>
      </nav>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "textarea",
      "id": "tagline",
      "label": "Footer tagline",
      "default": "A skincare platform dedicated to quality, science, and effortless skin."
    },
    {
      "type": "text",
      "id": "address",
      "label": "Address",
      "default": "21 Linking Road, Bandra West, Mumbai 400050"
    },
    {
      "type": "text",
      "id": "email",
      "label": "Contact email",
      "default": "hello@velara.in"
    },
    {
      "type": "text",
      "id": "phone",
      "label": "Phone number",
      "default": "+91 98765 43210"
    }
  ]
}
{% endschema %}
