<style>
  .gallery { background-color: var(--color-cream); position: relative; }

  .gallery__header {
    display: grid; grid-template-columns: 1fr; align-items: end;
    gap: var(--space-3); margin-bottom: var(--space-6);
  }
  @media (min-width: 810px) { .gallery__header { grid-template-columns: 1fr auto; gap: var(--space-6); } }

  .gallery__intro {
    font-family: var(--font-body);
    font-size: var(--text-xl);
    color: var(--color-black);
    max-width: 24ch;
    line-height: 1.3;
  }
  .gallery__intro em {
    font-family: var(--font-script);
    font-style: normal;
    color: var(--color-terracotta);
    font-size: 1.15em;
  }

  .gallery__feature { display: flex; align-items: baseline; gap: var(--space-2); }
  .gallery__word {
    font-family: var(--font-display);
    font-variation-settings: "opsz" 144, "SOFT" 100;
    font-size: clamp(3rem, 9vw, 8rem);
    font-weight: 700;
    color: var(--color-terracotta);
    font-style: italic;
    line-height: 0.9;
  }
  .gallery__counter {
    font-family: var(--font-display);
    font-variation-settings: "SOFT" 100;
    font-size: clamp(2.5rem, 6vw, 5rem);
    color: var(--color-black);
    background: var(--color-yellow);
    padding: 8px 20px;
    border-radius: var(--radius-md);
    border: 2px solid var(--color-black);
  }

  .gallery__grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    grid-auto-rows: 120px;
    gap: var(--space-2);
    position: relative;
  }
  @media (max-width: 1199.98px) { .gallery__grid { grid-template-columns: repeat(4, 1fr); grid-auto-rows: 100px; } }
  @media (max-width: 809.98px)  { .gallery__grid { grid-template-columns: repeat(2, 1fr); grid-auto-rows: 140px; } }

  .gallery__cell {
    overflow: hidden;
    border-radius: var(--radius-lg);
    border: 2px solid var(--color-black);
    background-color: var(--color-border);
  }
  .gallery__cell img { width: 100%; height: 100%; object-fit: cover; display: block; }

  .gallery__cell:nth-child(1) { grid-column: span 2; grid-row: span 3; }
  .gallery__cell:nth-child(2) { grid-column: span 2; grid-row: span 2; }
  .gallery__cell:nth-child(3) { grid-column: span 2; grid-row: span 3; }
  .gallery__cell:nth-child(4) { grid-column: span 3; grid-row: span 2; }
  .gallery__cell:nth-child(5) { grid-column: span 1; grid-row: span 2; }
  .gallery__cell:nth-child(6) { grid-column: span 2; grid-row: span 2; }
  .gallery__cell:nth-child(7) { grid-column: span 2; grid-row: span 2; }
  .gallery__cell:nth-child(8) { grid-column: span 2; grid-row: span 2; }
  .gallery__cell:nth-child(9) { grid-column: span 2; grid-row: span 2; }

  @media (max-width: 809.98px) {
    .gallery__cell { grid-column: span 1 !important; grid-row: span 1 !important; }
    .gallery__cell:nth-child(3n+1) { grid-row: span 2 !important; }
  }

  /* Sticker overlays */
  .gallery__overlay {
    position: absolute;
    font-family: var(--font-display);
    font-variation-settings: "SOFT" 100;
    pointer-events: none;
    line-height: 1;
  }
  .gallery__overlay--1 { top: 10%; left: 26%; font-size: clamp(2rem, 5vw, 4rem); color: var(--color-yellow);     background: var(--color-black);      padding: 8px 18px; border-radius: var(--radius-md); transform: rotate(-4deg); font-weight: 700; }
  .gallery__overlay--2 { top: 36%; right: 4%;  font-size: clamp(2.5rem, 6vw, 5rem); color: var(--color-black);   font-style: italic; font-family: var(--font-script); transform: rotate(4deg); }
  .gallery__overlay--3 { top: 64%; left: 10%;  font-size: clamp(2rem, 4.5vw, 3.5rem); color: var(--color-cream); background: var(--color-terracotta); padding: 8px 18px; border-radius: var(--radius-md); transform: rotate(3deg); font-weight: 700; }
  .gallery__overlay--4 { bottom: 8%; right: 16%; font-size: clamp(3rem, 7vw, 6rem); color: var(--color-black);    font-style: italic; font-family: var(--font-script); transform: rotate(-5deg); font-weight: 600; }

  @media (max-width: 809.98px) { .gallery__overlay { display: none; } }

  .gallery__placeholder {
    width: 100%; height: 100%;
    background: linear-gradient(135deg, var(--color-pink-soft) 0%, var(--color-yellow-soft) 100%);
  }
</style>

<section class="section gallery">
  <div class="container">
    <div class="gallery__header reveal">
      <p class="gallery__intro">{{ section.settings.intro | default: 'gallery.intro' | t }}</p>
      <div class="gallery__feature">
        <span class="gallery__word">{{ section.settings.word | default: 'gallery.word' | t }}</span>
      </div>
    </div>

    <div class="gallery__grid">
      {%- assign img_blocks = section.blocks | where: 'type', 'image' -%}
      {%- if img_blocks.size > 0 -%}
        {%- for block in img_blocks limit: 9 -%}
          <div class="gallery__cell" {{ block.shopify_attributes }}>
            {%- if block.settings.image -%}
              {{ block.settings.image | image_url: width: 1200 | image_tag:
                 loading: 'lazy',
                 width: block.settings.image.width,
                 height: block.settings.image.height,
                 alt: block.settings.image.alt | default: 'Editorial gallery image',
                 sizes: '(min-width: 1200px) 33vw, (min-width: 810px) 50vw, 100vw' }}
            {%- else -%}
              <div class="gallery__placeholder"></div>
            {%- endif -%}
          </div>
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..9) -%}
          <div class="gallery__cell"><div class="gallery__placeholder"></div></div>
        {%- endfor -%}
      {%- endif -%}

      {%- assign overlay_count = 1 -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'overlay' and overlay_count <= 4 -%}
          <span class="gallery__overlay gallery__overlay--{{ overlay_count }}" {{ block.shopify_attributes }}>
            {{ block.settings.text }}
          </span>
          {%- assign overlay_count = overlay_count | plus: 1 -%}
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Editorial Gallery",
  "settings": [
    { "type": "text", "id": "intro", "label": "Intro line", "default": "We bring science to life through" },
    { "type": "text", "id": "word", "label": "Feature word", "default": "Purity" }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Image",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" }
      ]
    },
    {
      "type": "overlay",
      "name": "Text overlay",
      "settings": [
        { "type": "text", "id": "text", "label": "Overlay text", "default": "CURATED" }
      ]
    }
  ],
  "max_blocks": 16,
  "presets": [
    {
      "name": "Editorial Gallery",
      "blocks": [
        { "type": "image" }, { "type": "image" }, { "type": "image" },
        { "type": "image" }, { "type": "image" }, { "type": "image" },
        { "type": "image" }, { "type": "image" }, { "type": "image" },
        { "type": "overlay", "settings": { "text": "CURATED" } },
        { "type": "overlay", "settings": { "text": "Glow" } },
        { "type": "overlay", "settings": { "text": "DAILY RITUAL" } },
        { "type": "overlay", "settings": { "text": "Purity" } }
      ]
    }
  ]
}
{% endschema %}
